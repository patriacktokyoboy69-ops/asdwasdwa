-- ✅ ลอยไปตำแหน่ง (float/lerp แทนการ teleport ทันที)
local function floatToPosition(targetPos)
    local root = Character:FindFirstChild("HumanoidRootPart")
    if not root or not targetPos then return end

    local startPos = root.Position
    local endPos = targetPos + Vector3.new(0, 5, 0)
    local steps = 20
    local stepWait = FLOAT_SPEED / steps

    for i = 1, steps do
        local alpha = i / steps
        local lerpPos = startPos:Lerp(endPos, alpha)
        root.CFrame = CFrame.new(lerpPos)
        task.wait(stepWait)
    end
end

-- ✅ ลอยไปหาต้นไม้ (float แทน teleport)
local function floatToTarget(part, offsetY)
    local root = Character:FindFirstChild("HumanoidRootPart")
    if not root or not part then return end

    local targetPos = part.Position - Vector3.new(0, offsetY or 0, 0)
    local startPos = root.Position
    local steps = 15
    local stepWait = FLOAT_SPEED / steps

    for i = 1, steps do
        local alpha = i / steps
        local lerpPos = startPos:Lerp(targetPos, alpha)
        root.CFrame = CFrame.new(lerpPos)
        task.wait(stepWait)
    end
end

local function findFoodNode()
    local foodFolder = workspace:FindFirstChild("Interactions")
        and workspace.Interactions:FindFirstChild("Nodes")
        and workspace.Interactions.Nodes:FindFirstChild("Food")

    if not foodFolder then return nil end

    for _, node in ipairs(foodFolder:GetChildren()) do
        if node:IsA("Model") and node.Name == "LargeFoodNode" then
            local part = node:FindFirstChild("BillboardPart")
            local health = part and part:FindFirstChild("Health")
            if part and health and health.Value > 0 then
                return node, part
            end
        end
    end
    return nil
end

local function sellEverythingInInventory()
    local res = LocalPlayer:FindFirstChild("Data") and LocalPlayer.Data:FindFirstChild("Resources")
    if not res then return end
    local args = {}
    for _, item in ipairs(res:GetChildren()) do
        if item:IsA("NumberValue") and item.Value >= 200 then
            table.insert(args, {
                ItemName = item.Name,
