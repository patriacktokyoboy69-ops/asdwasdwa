local function getRemote(name)
    if cachedRemotes[name] then return cachedRemotes[name] end

    for i = 1, 100 do
        local dragon = Character:FindFirstChild("Dragons") and Character.Dragons:FindFirstChild(tostring(i))
        if dragon and dragon:FindFirstChild("Remotes") then
            local remote = dragon.Remotes:FindFirstChild(name)
            if remote then
                cachedRemotes[name] = remote
                return remote
            end
        end
    end
    return nil
end

local function getHealth(part)
    return part and part:FindFirstChild("Health")
end

local lastPullTime = 0

local function pullItemToPlayer()
    local now = tick()
    if now - lastPullTime < PULL_INTERVAL then return end
    lastPullTime = now

    local root = Character:FindFirstChild("HumanoidRootPart")
    if not root then return end

    for _, source in ipairs({workspace, workspace:FindFirstChild("Camera")}) do
        if not source then continue end
        for _, obj in ipairs(source:GetChildren()) do
            if table.find(targetNames, obj.Name) and obj:IsA("Model") then
                pcall(function()
                    if not obj.PrimaryPart then
                        obj.PrimaryPart = obj:FindFirstChildWhichIsA("BasePart")
                    end
                    if obj.PrimaryPart then
                        obj:SetPrimaryPartCFrame(CFrame.new(root.Position + Vector3.new(0, 1, 0)))
                    end
                end)
            end
        end
    end
end

task.spawn(function()
    while true do
        pcall(pullItemToPlayer)
        task.wait(PULL_INTERVAL)
    end
end)

local function distanceXZ(a, b)
    local dxz = Vector3.new(a.X, 0, a.Z) - Vector3.new(b.X, 0, b.Z)
    return dxz.Magnitude
end

-- ✅ โจมตีและลงช้าๆ ทีละ DESCENT_STEP
local function attackTarget(part)
    local remote = getRemote("PlaySoundRemote")
    if not remote then return end

    local health = getHealth(part)
    if not health then return end
    if health.Value <= 0 then return end

    local root = Character:FindFirstChild("HumanoidRootPart")

    -- ลอยไปหาต้นไม้ก่อน (แทน teleport ทันที)
    if distanceXZ(root.Position, part.Position) > HORIZONTAL_DISTANCE_THRESHOLD then
        floatToTarget(part, TELEPORT_NEAR_TREE_OFFSET)
        task.wait(0.3)
    end

    local offset = MAX_UNDERGROUND_OFFSET
    local success = false

    -- ลงช้าๆ ทีละ DESCENT_STEP (เดิมลงทีละ 5 ไม่มี delay)
    while offset >= MIN_UNDERGROUND_OFFSET do
        floatToTarget(part, offset)     -- ลอยไปแทน teleport
        task.wait(DESCENT_WAIT)         -- หน่วงระหว่างลงแต่ละขั้น

        local before = health.Value
        for _ = 1, ATTACK_REPEAT do
            remote:FireServer("Breath", "Destructibles", part)
            task.wait(ATTACK_WAIT)      -- หน่วงระหว่าง attack แต่ละครั้ง
        end

        if health.Value < before then
            lastSafePosition = part.Position + Vector3.new(0, 10, 0)
            success = true
            break
        end
        offset -= DESCENT_STEP          -- ลงทีละน้อย (เดิม -= 5)
    end

    if success then
        while health.Value > 0 do
            for _ = 1, ATTACK_REPEAT do
                remote:FireServer("Breath", "Destructibles", part)
                task.wait(ATTACK_WAIT)
            end
            pullItemToPlayer()
            task.wait(0.1)
        end
    end

    floatToTarget(part, MAX_UNDERGROUND_OFFSET) -- ลอยกลับขึ้น
end

