    lighting.Brightness = 0
    lighting.OutdoorAmbient = Color3.new(0.1, 0.1, 0.1)
    lighting.Ambient = Color3.new(0.1, 0.1, 0.1)

    for _, effect in ipairs(lighting:GetChildren()) do
        if effect:IsA("PostEffect") then
            effect.Enabled = false
        end
    end

    local terrain = workspace:FindFirstChildOfClass("Terrain")
    if terrain then
        terrain.WaterTransparency = 1
        terrain.WaterReflectance = 0
        terrain.WaveSize = 0
        terrain.WaveSpeed = 0
    end

    settings().Rendering.QualityLevel = Enum.QualityLevel.Level01
    print("✅ ปรับ FPS เบื้องต้นเสร็จ")
end

local isObjectsRemoved = false
local function removeUnnecessaryObjects()
    if isObjectsRemoved then return end
    isObjectsRemoved = true

    print("🗑️ เริ่มลบโมเดลที่ไม่จำเป็น...")
    local objectsToDestroy = {}

    for _, obj in ipairs(workspace:GetDescendants()) do
        pcall(function()
            if obj:IsA("ParticleEmitter") or obj:IsA("Trail") or obj:IsA("Smoke")
               or obj:IsA("Fire") or obj:IsA("Beam") or obj:IsA("Explosion")
               or obj:IsA("Sparkles") then
                table.insert(objectsToDestroy, obj)
            elseif obj:IsA("PointLight") or obj:IsA("SpotLight") or obj:IsA("SurfaceLight") then
                obj.Enabled = false
            elseif obj:IsA("Decal") or obj:IsA("Texture") then
                obj.Transparency = 1
            elseif obj:IsA("BasePart") then
                obj.Material = Enum.Material.SmoothPlastic
                obj.Reflectance = 0
                obj.CastShadow = false
            end
        end)
    end

    for _, obj in ipairs(objectsToDestroy) do
        pcall(function() obj:Destroy() end)
    end

    print("✅ ลบโมเดลเสร็จ - ประมวลผล " .. #objectsToDestroy .. " objects")
end

local function optimizeRendering()
    local lighting = game:GetService("Lighting")
    lighting.GlobalShadows = false
    lighting.ShadowSoftness = 0
    workspace.StreamingEnabled = true
    workspace.StreamingMinRadius = 64
    workspace.StreamingTargetRadius = 128
    print("✅ ปรับ Rendering เสร็จ")
end

local function fullFPSBoost()
    print("🚀 เริ่มการปรับแต่ง FPS แบบเต็มรูปแบบ...")
    boostFPS()
    task.wait(0.3)
    removeUnnecessaryObjects()
    task.wait(0.3)
    optimizeRendering()
    print("🎯 ปรับแต่ง FPS เสร็จสิ้น!")
end

local function continuousCleanup()
    task.spawn(function()
        while true do
            if afkMode then
                pcall(function()
                    for _, obj in ipairs(workspace:GetDescendants()) do
                        if obj:IsA("ParticleEmitter") or obj:IsA("Trail") or obj:IsA("Beam") then
                            if obj.Enabled then obj.Enabled = false end
                        end
                    end
                end)
            end
            task.wait(10)
        end
    end)
end

